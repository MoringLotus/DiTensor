#pragma once#include "tensor.hpp"
#include "core/allocator.hpp"
#include "core/types.hpp"
#include <cuda_runtime.h>

namespace ditensor {
    Tensor Tensor::to(DeviceType target) const {
        if(this->device_ == target){
            return *this;
        }

        Tensor out(this->shape_, target, this->dtype_);

        size_t bytes = this->numel() * sizeof(float); // #FIX FOR OTHER DataType

        if(this->device_ == DeviceType::CPU && target == DeviceType::CUDA){
            void* d_ptr = nullptr;
            if(cudaMalloc(&d_ptr, bytes) != cudaSuccess){
                throw std::runtime_error("CUDA Malloc Failed");
            }
            cudaMemcpy(d_ptr, this->data_ptr_.get(), bytes, cudaMemcpyHostToDevice);

            out.data_ptr_ = std::shared_ptr<void>(d_ptr, [](void* p){
            cudaFree(p);
            });
            return out;
        } else if(this->device_ == DeviceType::CUDA && target ==DeviceType::CPU){
          void* h_ptr = malloc(bytes);
        
          // 将 GPU 数据拷贝回 CPU
          cudaMemcpy(h_ptr, this->data_ptr_.get(), bytes, cudaMemcpyDeviceToHost);

          out.data_ptr_ = std::shared_ptr<void>(h_ptr, [](void* p) {
            free(p);
          });
          return out;
        }
    }
    
    Tensor::Tensor(const std::vector<int> & shape, const DeviceType & device, const DataType & dtype ): shape_(shape), device_(device), dtype_(dtype){
        int nums = 1;
        for(int d : shape_){
            nums *= d;
        }

        size_t element_size = (dtype_ == DataType::FLOAT32) ? sizeof(float) : sizeof(int);
        size_t total_bytes = nums * element_size;

        if(device_ == DeviceType::CPU){
            void* raw_ptr = Allocator::instance().allocate(total_bytes);
            data_ptr_ = std::shared_ptr<void>(raw_ptr, [total_bytes](void* ptr) {
                Allocator::instance().deallocate(ptr, total_bytes);
            });
        }
    };
    Tensor::~Tensor(){};
}
